# ── DSGV Device Profile ───────────────────────────────────────────────────────
# Edit ONLY this file to change this device's identity and behaviour.
# GPIO pin map is determined automatically by the chip target passed at build:
#   idf.py -DIDF_TARGET=esp32c3 build   (ESP32-C3 / C6)
#   idf.py -DIDF_TARGET=esp32s3 build   (ESP32-S3)
#   idf.py -DIDF_TARGET=esp32   build   (ESP32 classic)
# ─────────────────────────────────────────────────────────────────────────────
CONFIG_DSGV_DEVICE_TYPE="Switch"
CONFIG_DSGV_DEVICE_CAPABILITIES="[\"relay\"]"
CONFIG_DSGV_RELAY_COUNT=1

# ── Partition table ───────────────────────────────────────────────────────────
# 4 MB flash: dual-bank OTA (1.8 MB each) + isolated Matter NVS (256 KB).
# To upgrade to 8 MB hardware, replace with:
#   CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="../../partitions_8mb.csv"
#   CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="../../partitions_4mb.csv"
