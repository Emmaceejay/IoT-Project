# DSGV Firmware SDK Config Defaults
# These override ESP-IDF defaults for production IoT use

# ── Partition table ───────────────────────────────────────────────────────────
# Always use a custom CSV so partition layout is explicit and version-controlled.
# Path is relative to each device project root (devices/<device_name>/), so
# ../../ navigates up to the repo root where the CSV files live.
# Default: 4 MB dual-bank OTA + isolated Matter NVS (partitions_4mb.csv).
# Override per-device to partitions_8mb.csv for 8 MB hardware variants.

# ── MQTT ─────────────────────────────────────────────────────────────────────
CONFIG_MQTT_BUFFER_SIZE=2048
CONFIG_MQTT_TASK_STACK_SIZE=6144

# ── Secure Boot / Flash Encryption (enable for production) ───────────────────
# CONFIG_SECURE_BOOT=y
# CONFIG_FLASH_ENCRYPTION_ENABLED=y

# ── Matter / CHIP SDK ─────────────────────────────────────────────────────────
CONFIG_ENABLE_CHIP_SHELL=n
CONFIG_CHIP_ENABLE_PAIRING_AUTOSTART=y
CONFIG_CHIP_TASK_STACK_SIZE=8192
# Disable Matter's own OTA requestor — dsgv_ota.c handles OTA for this project.
# Saves ~100 KB of binary space, which is significant on 4 MB flash.
CONFIG_CHIP_OTA_REQUESTOR=n
# Use the ESP-IDF system heap allocator instead of CHIP's internal allocator.
# Reduces memory fragmentation and ROM footprint.
CONFIG_CHIP_MALLOC_SYS_HEAP=y
# Store all Matter pairing and fabric data in a dedicated NVS partition so
# that a Matter factory-reset (decommission from HomeKit / Google Home / Alexa)
# erases ONLY Matter pairing data, not Wi-Fi creds or device config.
CONFIG_CHIP_NVS_PARTITION_NAME="matter_nvs"

# ── TLS / mbedTLS ─────────────────────────────────────────────────────────────
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_TLS_CLIENT=y

# ── BLE / NimBLE (for Wi-Fi provisioning on first boot) ──────────────────────
# NimBLE works on ESP32-C3, ESP32-C6, and ESP32-S3 out of the box.
# For the original ESP32 (classic), also add:
#   CONFIG_BTDM_CTRL_MODE_BLE_ONLY=y
# to restrict the dual-mode BT controller to BLE-only and enable NimBLE.
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_INTERNAL=y
CONFIG_BT_NIMBLE_LOG_LEVEL_NONE=y

# ── Compiler optimisations ────────────────────────────────────────────────────
# Optimise for size rather than speed. Critical for fitting Matter + MQTT +
# BLE + OTA into a 1.8 MB OTA slot on 4 MB flash. Safe for all IoT workloads
# in this project (no floating-point-heavy or latency-critical hot paths).
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# ── Logging (reduce in production) ───────────────────────────────────────────
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="../../partitions_4mb.csv"
